# =============================================================
# Imprint Studio — Variables de entorno
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# =============================================================

# Django
DJANGO_SECRET_KEY=cambia-esto-por-una-clave-segura-de-50-chars
DEBUG=False
ALLOWED_HOSTS=tudominio.com,www.tudominio.com

# Base de datos (PostgreSQL en producción)
USE_SQLITE=false
DB_NAME=imprint_studio
DB_USER=imprint_user
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS — solo el frontend oficial
CORS_ALLOWED_ORIGINS=https://tudominio.com

# OTP
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Cloudinary — almacenamiento de archivos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Brevo — envío de emails
BREVO_API_KEY=

# WhatsApp Business Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_ID=

# Scheduler APScheduler (true en producción con gunicorn, false en desarrollo)
SCHEDULER_AUTOSTART=false

# Logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
DJANGO_LOG_LEVEL=INFO
